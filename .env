# ============================================
# KINVA MASTER - ENVIRONMENT VARIABLES
# ============================================

# Telegram API Credentials (from https://my.telegram.org)
API_ID=1234567
API_HASH=your_api_hash_here

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here
BOT_USERNAME=@kinva_master_bot

# Web App URL (for deployment)
WEBAPP_URL=https://kinva-master.onrender.com
API_URL=https://api.kinva-master.com

# ============================================
# Admin Configuration
# ============================================
ADMIN_IDS=123456789,987654321
ADMIN_CONTACT=@kinva_master
ADMIN_EMAIL=admin@kinva-master.com
ADMIN_USERNAME=kinva_master

# ============================================
# App Settings
# ============================================
SECRET_KEY=your_super_secret_key_change_this_in_production
DEBUG=False
HOST=0.0.0.0
PORT=5000
FLASK_ENV=production

# ============================================
# Database
# ============================================
DATABASE_URL=sqlite:///kinva_master.db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (Optional)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================
# Stripe Payment
# ============================================
STRIPE_PUBLIC_KEY=pk_live_your_key_here
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
STRIPE_SUCCESS_URL=https://kinva-master.com/success
STRIPE_CANCEL_URL=https://kinva-master.com/cancel

# ============================================
# Premium Pricing (in USD)
# ============================================
PREMIUM_PRICE_MONTHLY=14.99
PREMIUM_PRICE_YEARLY=119.99
PREMIUM_PRICE_LIFETIME=299.99

# ============================================
# Watermark Settings
# ============================================
WATERMARK_TEXT=@kinva_master.com
WATERMARK_IMAGE=static/images/watermark.png
WATERMARK_OPACITY=0.5
WATERMARK_POSITION=bottom-right
WATERMARK_SIZE=100
WATERMARK_FONT_SIZE=24
WATERMARK_FONT_COLOR=#ffffff

# ============================================
# Video Processing Settings
# ============================================
MAX_VIDEO_SIZE=500
MAX_VIDEO_LENGTH=3600
ALLOWED_VIDEO_FORMATS=mp4,avi,mov,mkv,webm,flv
VIDEO_QUALITY=medium
VIDEO_COMPRESSION_LEVEL=medium

# ============================================
# Image Processing Settings
# ============================================
MAX_IMAGE_SIZE=50
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,gif,bmp,webp
IMAGE_QUALITY=90

# ============================================
# Cloud Storage (Optional)
# ============================================
# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=kinva-master
AWS_REGION=us-east-1

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT=100
RATE_LIMIT_PERIOD=60
RATE_LIMIT_BY_IP=True

# ============================================
# Logging
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_FORMAT=json
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# ============================================
# Email Configuration (Optional)
# ============================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@kinva-master.com
MAIL_PASSWORD=your_password
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_DEFAULT_SENDER=noreply@kinva-master.com

# ============================================
# Cache Settings
# ============================================
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300
CACHE_KEY_PREFIX=kinva_

# ============================================
# Session Settings
# ============================================
SESSION_TYPE=filesystem
SESSION_PERMANENT=True
SESSION_USE_SIGNER=True
SESSION_KEY_PREFIX=kinva_session_

# ============================================
# Security
# ============================================
BCRYPT_ROUNDS=12
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=2592000

# ============================================
# API Keys (Third Party Services)
# ============================================
# Google
GOOGLE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Twitter
TWITTER_API_KEY=
TWITTER_API_SECRET=

# Instagram
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
